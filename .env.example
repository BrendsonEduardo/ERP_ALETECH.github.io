# Django Core
SECRET_KEY=sua-secret-key-aqui-gere-uma-nova-em-producao
DEBUG=True

# Hosts permitidos (separados por vírgula, sem espaços)
ALLOWED_HOSTS=192.168.15.16,127.0.0.1,localhost

# Google Sheets — Helpdesk Integration
GOOGLE_SHEETS_CREDENTIALS_PATH=credenciais.json
GOOGLE_SHEETS_PLANILHA_ID=ID_DA_SUA_PLANILHA_AQUI
